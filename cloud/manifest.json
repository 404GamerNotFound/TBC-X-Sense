{
  "schema_version": 1,
  "key": "xsense-cloud",
  "label": "X-Sense",
  "version": "1.0.0",
  "description": "Lists X-Sense account cameras (serial, name, model) for manual import - unofficial, reverse-engineered API",
  "entrypoint": "plugin.py",
  "auth_type": "credentials",
  "verification_support": "not_applicable",
  "account_fields": [
    {
      "key": "email",
      "label": "Email address",
      "type": "email",
      "required": true,
      "autocomplete": "username"
    },
    {
      "key": "password",
      "label": "Password",
      "type": "password",
      "required": true,
      "autocomplete": "current-password"
    }
  ]
}
